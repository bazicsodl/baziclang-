struct User {
    name: string
    age: int
}


enum Role { Guest, Admin }


fn make_user(name: string, age: int): User {
    return User { age: age, name: name }
}


fn identity[T](x: T): T {
    return x
}


fn role_name(role: Role): string {
    if (role == Admin) {
        return "admin"
    }
    return "guest"
}
