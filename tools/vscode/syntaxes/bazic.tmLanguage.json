{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Bazic",
  "scopeName": "source.bazic",
  "patterns": [
    { "include": "#comment" },
    { "include": "#string" },
    { "include": "#number" },
    { "include": "#keyword" },
    { "include": "#type" },
    { "include": "#function" },
    { "include": "#constant" },
    { "include": "#operator" }
  ],
  "repository": {
    "comment": {
      "patterns": [
        {
          "name": "comment.line.double-slash.bazic",
          "match": "//.*$"
        }
      ]
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.double.bazic",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.bazic",
              "match": "\\\\(\\\\|\"|n|r|t)"
            }
          ]
        }
      ]
    },
    "number": {
      "patterns": [
        {
          "name": "constant.numeric.float.bazic",
          "match": "\\b-?(?:\\d+\\.\\d+|\\d+\\.)(?:[eE][+-]?\\d+)?\\b"
        },
        {
          "name": "constant.numeric.integer.bazic",
          "match": "\\b-?\\d+\\b"
        }
      ]
    },
    "keyword": {
      "patterns": [
        {
          "name": "keyword.control.bazic",
          "match": "\\b(fn|let|const|if|else|while|for|match|return|break|continue|import|enum|struct|interface|impl)\\b"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "name": "storage.type.bazic",
          "match": "\\b(int|float|string|bool|any|void)\\b"
        }
      ]
    },
    "function": {
      "patterns": [
        {
          "name": "entity.name.function.bazic",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "constant": {
      "patterns": [
        {
          "name": "constant.language.bazic",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operator": {
      "patterns": [
        {
          "name": "keyword.operator.bazic",
          "match": "==|!=|<=|>=|&&|\\|\\||\\+|\\-|\\*|/|%|=|<|>"
        }
      ]
    }
  }
}
