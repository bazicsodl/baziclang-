    let head = ui_element("thead", ui_props("", "table-head"), ui_children_one(head_json))
    let body = ui_element("tbody", ui_props("", "table-body"), ui_children_one(body_json))
    return ui_element("table", ui_props("", "table"), ui_children_two(head, body))
}


fn ui_table_class(head_json: string, body_json: string, class_name: string): string {
    let head = ui_element("thead", ui_props("", "table-head"), ui_children_one(head_json))
    let body = ui_element("tbody", ui_props("", "table-body"), ui_children_one(body_json))
    return ui_element("table", ui_props("", ("table " + class_name)), ui_children_two(head, body))
}


fn ui_table_row(cells_json: string): string {
    return ui_element("tr", ui_props("", "table-row"), cells_json)
}


fn ui_table_cell(text: string): string {
    return ui_element("td", ui_props("", "table-cell"), ui_children_one(ui_text(text)))
}


fn ui_table_head_cell(text: string): string {
    return ui_element("th", ui_props("", "table-head-cell"), ui_children_one(ui_text(text)))
}


fn ui_table_head_cell_sort(label: string, id: string, dir: string): string {
    let cls = "table-sort"
    if (dir == "asc") {
        cls = "table-sort active asc"
    }
    if (dir == "desc") {
        cls = "table-sort active desc"
    }
    let btn = ui_element("button", ui_props(id, cls), ui_children_one(ui_text(label)))
    return ui_element("th", ui_props("", "table-head-cell"), ui_children_one(btn))
}


fn ui_table_cell_span(text: string, span: int): string {
    let props = (("{\"class\":\"table-cell\",\"colspan\":" + str(span)) + "}")
    return ui_element("td", props, ui_children_one(ui_text(text)))
}


fn ui_menu(items_json: string): string {
    return ui_element("ul", ui_props("", "menu"), items_json)
}


fn ui_menu_item(label: string, id: string, is_active: bool): string {
    let cls = "menu-item"
    if is_active {
        cls = "menu-item active"
    }
    let btn = ui_element("button", ui_props(id, cls), ui_children_one(ui_text(label)))
    return ui_element("li", ui_props("", "menu-row"), ui_children_one(btn))
}


fn ui_dropdown(label: string, id: string, is_open: bool, items_json: string): string {
    let btn = ui_element("button", ui_props(id, "dropdown-trigger"), ui_children_one(ui_text(label)))
    let menu_cls = "dropdown-menu"
    if !is_open {
        menu_cls = "dropdown-menu hidden"
    }
    let menu = ui_element("div", ui_props("", menu_cls), ui_children_one(ui_menu(items_json)))
    return ui_element("div", ui_props("", "dropdown"), ui_children_two(btn, menu))
}


fn ui_modal(title: string, body_json: string, is_open: bool): string {
    let cls = "modal"
    if !is_open {
        cls = "modal hidden"
    }
    let head = ui_element("div", ui_props("", "modal-head"), ui_children_one(ui_text(title)))
    let body = ui_element("div", ui_props("", "modal-body"), ui_children_one(body_json))
    let panel = ui_element("div", ui_props("", "modal-panel"), ui_children_two(head, body))
    return ui_element("div", ui_props("", cls), ui_children_one(panel))
}


fn ui_section(title: string, body_json: string): string {
    let t = ui_element("h2", ui_props("", "section-title"), ui_children_one(ui_text(title)))
    return ui_element("section", ui_props("", "section"), ui_children_two(t, body_json))
}


fn ui_form_row(label: string, input_json: string): string {
    let l = ui_element("div", ui_props("", "form-label"), ui_children_one(ui_text(label)))
    let field = ui_element("div", ui_props("", "form-field"), ui_children_one(input_json))
    return ui_element("div", ui_props("", "form-row"), ui_children_two(l, field))
}


fn ui_toast(message: string, tone: string): string {
    let cls = "toast"
    if (tone != "") {
        cls = ("toast " + tone)
    }
    return ui_element("div", ui_props("", cls), ui_children_one(ui_text(message)))
}


fn ui_toast_stack(toasts_json: string): string {
    return ui_element("div", ui_props("", "toast-stack"), toasts_json)
}


fn ui_empty(text: string): string {
    return ui_element("div", ui_props("", "empty"), ui_children_one(ui_text(text)))
}


fn ui_page(page: string, name: string, body_json: string): string {
    let cls = "page hidden"
    if (page == name) {
        cls = "page active"
    }
    return ui_element("section", ui_props_key(("page-" + name), cls, ("page-" + name)), ui_children_one(body_json))
}


fn ui_render_from_state(title: string, subtitle: string, clicks: int, page: string): string {
    let sub = ui_p(subtitle)
    let status = ui_p(("Clicks: " + str(clicks)))
    let btn = ui_button("Click Me", "btn", "ghost")
    let input = ui_bind_input("name", "Type your name", "name")
    let nav_home = ui_nav_link("Home", "nav-home", (page == "home"))
    let nav_about = ui_nav_link("About", "nav-about", (page == "about"))
    let nav = ui_element("nav", ui_props_key("nav", "nav", "nav"), ui_children_two(nav_home, nav_about))
    let hero = ui_element("div", ui_props("", "hero"), ui_children_two(btn, input))
    let content = ui_element("div", ui_props("", "content"), ui_children_three(sub, hero, status))
    let list_title = ui_element("h3", ui_props_key("", "list-title", "list-title"), ui_children_one(ui_text("Items")))
    let item1 = ui_element("div", ui_props_key("", "item", "i1"), ui_children_one(ui_text("One")))
    let item2 = ui_element("div", ui_props_key("", "item", "i2"), ui_children_one(ui_text("Two")))
    let item3 = ui_element("div", ui_props_key("", "item", "i3"), ui_children_one(ui_text("Three")))
    let list = ui_element("div", ui_props_key("", "list", "list"), ui_children_three(item1, item2, item3))
    let home_body = ui_element("div", ui_props("", "stack"), ui_children_three(ui_p("Welcome to Bazic UI."), list_title, list))
    let about_body = ui_element("div", ui_props("", "stack"), ui_children_three(ui_p("Bazic UI is a minimal JSON UI DSL."), ui_p("Runs on WASM via the Go backend."), ui_p("Interop ready for React.")))
    let home_page = ui_page(page, "home", ui_section("Home", home_body))
    let about_page = ui_page(page, "about", ui_section("About", about_body))
    let pages = ui_element("div", ui_props("", "pages"), ui_children_two(home_page, about_page))
    let body = ui_element("div", ui_props("", "content"), ui_children_two(content, pages))
    let root = ui_layout(title, nav, body)
    let _ = ui_render(root)
    return "ok"
}
