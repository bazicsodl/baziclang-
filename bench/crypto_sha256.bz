import "std"


fn main(): void {
    let n = 20000
    let s = "The quick brown fox jumps over the lazy dog"
    let i = 0
    let start = time_unix_millis()
    while (i < n) {
        let h = crypto_sha256_hex(s)
        if (len(h) == 0) {
            println("0")
            return
        }
        i = (i + 1)
    }
    let end = time_unix_millis()
    println(str((end - start)))
}
