import "std"


fn main(): void {
    let n = 20000000
    let i = 0
    let sum = 0
    let start = time_unix_millis()
    while (i < n) {
        sum = (sum + i)
        i = (i + 1)
    }
    let end = time_unix_millis()
    if (sum == -1) {
        println("never")
    }
    println(str((end - start)))
}
