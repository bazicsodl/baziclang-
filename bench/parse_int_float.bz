import "std"


fn main(): void {
    let n = 200000
    let i = 0
    let start = time_unix_millis()
    while (i < n) {
        let r1 = parse_int("12345")
        let r2 = parse_float("3.14159")
        if (!r1.is_ok || !r2.is_ok) {
            println("0")
            return
        }
        i = (i + 1)
    }
    let end = time_unix_millis()
    println(str((end - start)))
}
