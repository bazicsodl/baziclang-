import "std"


fn main(): void {
    let n = 200000
    let sb = sb_new()
    let i = 0
    let start = time_unix_millis()
    while (i < n) {
        sb = sb_append(sb, "a")
        i = (i + 1)
    }
    let out = sb_string(sb)
    let end = time_unix_millis()
    if (len(out) == 0) {
        println("0")
        return
    }
    println(str((end - start)))
}
