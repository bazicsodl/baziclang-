import "std"


fn main(): void {
    let n = 20000
    let json = "{\"a\":1,\"b\":2,\"c\":[1,2,3,4,5],\"d\":{\"x\":true,\"y\":false}}"
    let i = 0
    let ok = true
    let start = time_unix_millis()
    while (i < n) {
        ok = json_validate(json)
        i = (i + 1)
    }
    let end = time_unix_millis()
    if !ok {
        println("0")
        return
    }
    println(str((end - start)))
}
